# ─────────────────────────────────────────────────────────────────────────────
# Cenlub RFQ Pipeline — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# Neon PostgreSQL connection string (Phase 0–4 DB-backed pipeline)
# Get from: Neon console → Connection Details → Connection string
DATABASE_URL=postgresql://neondb_owner:<password>@ep-curly-dust-at68muqf-pooler.c-9.us-east-1.aws.neon.tech/neondb?sslmode=require&channel_binding=require

# Google Gemini API key (primary LLM — Phase 1.3, 2.5, 3.4, 3.6, checklist)
GEMINI_API_KEY=your_gemini_api_key_here

# Groq API key (BOM extraction Tier 1 — optional, falls back to Gemini)
GROQ_API_KEY=your_groq_api_key_here

# SMTP email sending (Phase 5.3 missing doc alert, Phase 6 vendor inquiry)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=rfq@cenlub.com
SMTP_PASS=your_smtp_password_here

# Email listener (Phase 1.1 — IMAP polling)
IMAP_HOST=imap.gmail.com
IMAP_USER=rfq@cenlub.com
IMAP_PASS=your_imap_password_here

# Microsoft Graph API (alternative to IMAP for Office 365 inbox)
# EMAIL_CLIENT_ID=
# EMAIL_CLIENT_SECRET=
# EMAIL_TENANT_ID=
